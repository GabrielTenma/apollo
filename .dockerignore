# Git
.git
.github/**
.gitattributes
.gitignore

# Dependencies
node_modules/

# Secrets — NEVER bake any real .env into the image.
# All configuration must be supplied at `docker run` time via --env-file or -e flags.
# .env.example is intentionally allowed (safe template only).
.env
.env.*
!.env.example

# Bun
bunfig.toml

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# TypeScript build output not needed in image
src/**/*.js
src/**/*.js.map
src/**/*.d.ts

# Frontend local dev
src/web/dist/
src/web/node_modules/

# Test reports / coverage
coverage/
test-results/
