{
	"name": "apollo",
	"version": "1.0.1",
	"description": "",
	"author": "GabrielTenma",
	"private": true,
	"license": "Apache-2.0",
	"scripts": {
		"build": "nest build && cp .env.example dist/.env",
		"build:all": "npm run build && npm run web:build",
		"format": "biome format --write",
		"web:dev": "vite --config vite.config.ts",
		"web:build": "vite build --config vite.config.ts",
		"web:preview": "vite preview",
		"dev": "concurrently \"npm run start:dev\" \"npm run web:dev\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"start:all": "node dist/main",
		"lint": "biome check --fix \"src\" \"test\" \"src/web/src\"",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json"
	},
	"dependencies": {
		"@biomejs/biome": "^2.4.15",
		"@nestjs/common": "^9.0.0",
		"@nestjs/config": "^2.3.4",
		"@nestjs/core": "^9.0.0",
		"@nestjs/jwt": "^9.0.0",
		"@nestjs/passport": "^9.0.3",
		"@nestjs/platform-express": "^9.0.0",
		"@nestjs/serve-static": "^5.0.5",
		"@nestjs/typeorm": "^9.0.0",
		"@nestjs/cli": "^10.0.0",
		"@supabase/supabase-js": "^2.105.4",
		"@types/bcrypt": "^6.0.0",
		"@vitejs/plugin-react": "^6.0.2",
		"bcrypt": "^6.0.0",
		"better-sqlite3": "^12.10.0",
		"cheerio": "^1.2.0",
		"evlog": "^2.17.0",
		"ink": "^3.0.1",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"pg": "^8.11.3",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-markdown": "^10.1.0",
		"reflect-metadata": "^0.1.13",
		"remark-gfm": "^4.0.1",
		"rxjs": "^7.2.0",
		"supabase-js": "^0.0.1-security",
		"typeorm": "^0.3.17",
		"vite": "^8.0.13",
		"webpack": "^5.106.2",
		"webpack-cli": "^7.0.2"
	},
	"devDependencies": {
		"@iconify-json/tabler": "^1.2.35",
		"@iconify/tailwind4": "^1.2.3",
		"@nestjs/cli": "^9.0.0",
		"@nestjs/schematics": "^9.0.0",
		"@nestjs/testing": "^9.0.0",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.3.0",
		"@types/express": "^4.17.13",
		"@types/jest": "29.2.4",
		"@types/node": "18.11.18",
		"@types/passport-jwt": "^4.0.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/supertest": "^2.0.11",
		"autoprefixer": "^10.5.0",
		"concurrently": "^9.2.1",
		"daisyui": "^5.5.19",
		"esbuild": "^0.28.0",
		"flyonui": "^2.4.1",
		"jest": "29.3.1",
		"postcss": "^8.5.14",
		"source-map-support": "^0.5.20",
		"supertest": "^6.1.3",
		"tailwindcss": "^4.3.0",
		"ts-jest": "29.0.3",
		"ts-loader": "^9.2.3",
		"ts-node": "^10.0.0",
		"tsconfig-paths": "4.1.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
